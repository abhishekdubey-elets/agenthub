# --- Core ---
# For zero-config local dev, leave as SQLite. For production use Postgres:
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/agenthub
DATABASE_URL=sqlite:///./agenthub.db

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- OpenAI ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# --- Stripe (optional for dev) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
STRIPE_SUCCESS_URL=http://localhost:3000/dashboard?checkout=success
STRIPE_CANCEL_URL=http://localhost:3000/dashboard?checkout=cancel

# --- Google OAuth: Calendar + Gmail (optional) ---
# Create an OAuth 2.0 Client (type: Web application) at
# https://console.cloud.google.com/apis/credentials
# Enable BOTH the "Google Calendar API" and the "Gmail API", and add this exact
# redirect URI: http://localhost:8000/api/integrations/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/integrations/google/callback

# --- Slack OAuth (optional) ---
# Create a Slack app at https://api.slack.com/apps, add user-token scopes
# (channels:history, channels:read, groups:history, im:history, users:read),
# and add this Redirect URL under OAuth & Permissions:
#   http://localhost:8000/api/integrations/slack/callback
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=http://localhost:8000/api/integrations/slack/callback

# --- Email / SMTP (optional, for sending reports) ---
# For Gmail: host=smtp.gmail.com port=587, user=you@gmail.com,
# password = a Google "App Password" (not your normal password).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

# --- CORS ---
FRONTEND_ORIGIN=http://localhost:3000
